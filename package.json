{
  "name": "@sinamtz/pi-minimax-provider",
  "version": "1.0.9",
  "description": "Pi coding agent provider for MiniMax AI - supports MiniMax M2 series models with Anthropic API compatibility",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "check": "tsc --noEmit",
    "lint": "eslint *.ts",
    "test": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "minimax",
    "minimax-ai",
    "minimax-provider",
    "minimaxio",
    "provider",
    "authentication",
    "token"
  ],
  "author": {
    "name": "Sina Montazeri",
    "url": "https://github.com/sinamtz"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinamtz/pi-minimax-provider.git"
  },
  "bugs": {
    "url": "https://github.com/sinamtz/pi-minimax-provider/issues"
  },
  "homepage": "https://github.com/sinamtz/pi-minimax-provider#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
