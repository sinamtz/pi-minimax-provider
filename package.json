{
  "name": "@sinamtz/pi-minimax-provider",
  "version": "1.0.0",
  "description": "Pi coding agent provider for MiniMax AI - supports MiniMax M2 series models with Anthropic API compatibility",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build - TypeScript is interpreted by pi'",
    "check": "tsc --noEmit 2>/dev/null || echo 'TypeScript check skipped'"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pi",
    "pi-package",
    "extension"
  ],
  "author": {
    "name": "Sina Montazeri",
    "url": "https://github.com/sinamtz"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinamtz/pi-minimax-provider.git"
  },
  "bugs": {
    "url": "https://github.com/sinamtz/pi-minimax-provider/issues"
  },
  "homepage": "https://github.com/sinamtz/pi-minimax-provider#readme",
  "files": [
    "index.ts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
